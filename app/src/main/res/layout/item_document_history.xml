<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    card_view:cardCornerRadius="20dp"
    card_view:cardElevation="8dp"
    card_view:cardUseCompatPadding="true"
    card_view:cardBackgroundColor="#1E293B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivFileIcon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@android:drawable/ic_menu_save"
                android:contentDescription="File Icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/tvFileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="resume.pdf"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:maxLines="2" />

                <TextView
                    android:id="@+id/tvFileType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Type: PDF"
                    android:textSize="13sp"
                    android:textColor="#B8C1EC"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvOriginalSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Original: 1000 KB"
            android:textSize="14sp"
            android:textColor="#E2E8F0"
            android:layout_marginTop="14dp" />

        <TextView
            android:id="@+id/tvCompressedSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compressed: 700 KB"
            android:textSize="14sp"
            android:textColor="#E2E8F0"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvSavings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saved: 30%"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#22C55E"
            android:layout_marginTop="4dp" />

        <!-- ✅ STATUS BADGE -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compressed Successfully"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textColor="#FFFFFF"
            android:background="@drawable/chip_bg" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="16dp">

            <ImageButton
                android:id="@+id/btnDownloadHistory"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/stat_sys_download_done"
                android:background="@drawable/chip_bg"
                android:contentDescription="Download"
                android:padding="10dp"
                android:tint="#FFFFFF"
                android:layout_marginEnd="10dp" />

            <ImageButton
                android:id="@+id/btnShareHistory"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_share"
                android:background="@drawable/chip_bg"
                android:contentDescription="Share"
                android:padding="10dp"
                android:tint="#FFFFFF"
                android:layout_marginEnd="10dp" />

            <ImageButton
                android:id="@+id/btnDeleteHistory"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="@drawable/chip_bg"
                android:contentDescription="Delete"
                android:padding="10dp"
                android:tint="#FF6B6B" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>